# IVD MCP Server Configuration
#
# Required env vars (canonical list: mcp_server/env_check.py)
# When adding a new required var, add it here AND in env_check.py AND .do/app.yaml

# API keys for MCP access (comma-separated)
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
IVD_API_KEYS=

# OpenAI API key (for ivd_search embedding generation)
OPENAI_API_KEY=sk-...

# Redis connection URL (for MCP session resumability across restarts)
# Local: redis://localhost:6379  |  Production: set in .do/app.yaml
REDIS_URL=

# Auth disable (local dev only)
MCP_AUTH_DISABLED=true

# Path prefix (for DO reverse proxy, leave empty for local)
MCP_PATH_PREFIX=

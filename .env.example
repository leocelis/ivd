# IVD MCP Server — Environment Configuration
# Copy this file to .env and fill in your values.
# 14 of 15 tools work WITHOUT any keys.
# OPENAI_API_KEY is only needed for ivd_search (embedding generation + queries).

# --- Optional: Embeddings + Semantic Search ---
# Required to generate embeddings (./mcp_server/devops/embed.sh)
# and to run ivd_search queries at runtime.
# Get one at: https://platform.openai.com/api-keys
OPENAI_API_KEY=

# --- Optional: Remote Server Deployment Only ---
# Not needed for local stdio usage.
# Set this if self-hosting on a server with Redis for session resumability.
REDIS_URL=

# --- Optional: Remote Auth (self-hosted server only) ---
# Comma-separated API keys for authenticating remote MCP clients.
# Not needed for local stdio usage.
IVD_API_KEYS=

# --- Optional: Logging ---
# LOG_DIR=mcp_server/logs/
# LOG_RETENTION_DAYS=365
# LOG_LEVEL=INFO
